---

import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const {title = "Works", description = "The works of Sean Jefferson M. Calaoagan, a.k.a. XianShizukana"} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description}>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="min-h-screen bg-pink-700">
		<Nav />
        <section class="py-30 px-5 lg:p-30">
            <h1 class="text-4xl lg:text-6xl text-center font-extrabold mb-5 text-pink-100">{title}</h1>
			<slot />
        </section>
	</body>
</html>


